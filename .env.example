# shadcnblocks pro registry — required ONLY at component install/dev time
# (e.g. `npx shadcn add @shadcnblocks/dashboard18`). It is NEVER read at
# runtime and is NEVER shipped in the release binary. Get your key from the
# shadcnblocks dashboard: https://www.shadcnblocks.com
SHADCNBLOCKS_API_KEY=replace-me

# Dev only: where the web app finds the Rust API during `next dev`.
# Leave UNSET for release builds — the single binary serves the API same-origin.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8080
