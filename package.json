{
  "name": "harness-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first dashboard for AI coding usage, costs, productivity, DORA, and DevEx analytics. Rust backend, Next.js frontend, shipped as a single binary.",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.15"
    }
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:lan": "concurrently -k -n api,web -c blue,green \"pnpm dev:api:lan\" \"pnpm dev:web\"",
    "dev:web": "pnpm --filter @harness/web dev",
    "dev:api": "cargo run -p harness-server -- --dev",
    "dev:api:lan": "cargo run -p harness-server -- --dev --host 0.0.0.0",
    "build:web": "pnpm --filter @harness/web build",
    "build:server": "cargo build --release -p harness-server --features release-embed",
    "build": "pnpm build:web && pnpm build:server",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:rust": "cargo test",
    "format": "prettier --write . && cargo fmt",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "prettier": "^3",
    "turbo": "^2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8"
  }
}
